generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users          User[]
  startupProfile StartupProfile?
  connectedTools ConnectedTool[]
  tasks          Task[]
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model StartupProfile {
  id          String   @id @default(uuid())
  tenantId    String   @unique
  industry    String
  stage       String
  teamSize    Int?
  description String?
  goals       String?
  competitors String?
  tools       String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model ConnectedTool {
  id           String    @id @default(cuid())
  tenantId     String
  toolName     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  @@unique([tenantId, toolName])
  @@map("connected_tools")
}

model Task {
  id        String   @id @default(cuid())
  tenantId  String
  agentName String
  goal      String
  status    String   @default("pending_approval")
  output    Json?
  toEmail   String?
  subject   String?
  body      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  @@map("tasks")
}