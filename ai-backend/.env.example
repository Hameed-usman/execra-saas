# Get this from your OpenAI dashboard
OPENAI_API_KEY="your-openai-api-key"

# Get this from your Tavily account
TAVILY_API_KEY="your-tavily-api-key"

# Same PostgreSQL used by Next.js/Prisma — do not create a separate database
DATABASE_URL="postgresql://execra:execra_local_pass@localhost:5432/execra"

# Your n8n webhook URL for Gmail automation
N8N_GMAIL_WEBHOOK="your-n8n-webhook-url"

# The NEXTAUTH_SECRET from your existing Next.js .env
JWT_SECRET="921503c80a273b0a701b2a9d8cb44183023da562cfcc001db107ba0d97036495"

# Get free API key from https://openrouter.ai — no credit card required
OPENROUTER_API_KEY=your-openrouter-key-here

# Controls which LLM provider all agents use
# Options: openrouter (free/MVP), openai (production), gemini (future)
LLM_PROVIDER=openrouter
